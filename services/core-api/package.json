{
  "name": "@dvc/core-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "type-check:workers": "tsc -p tsconfig.workers.json --noEmit",
    "dev:workers": "wrangler dev --config wrangler.epsw.toml",
    "deploy:workers": "wrangler deploy --config wrangler.epsw.toml",
    "d1:schema:local": "wrangler d1 execute ${D1_DATABASE_NAME:-epsw-core-db} --config wrangler.epsw.toml --file ./d1/schema.sql --local",
    "d1:schema:remote": "wrangler d1 execute ${D1_DATABASE_NAME:-epsw-core-db} --config wrangler.epsw.toml --file ./d1/schema.sql --remote",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@dvc/database": "workspace:*",
    "@dvc/logger": "workspace:*",
    "@dvc/shared-types": "workspace:*",
    "better-auth": "^1.4.3",
    "better-sqlite3": "^12.9.0",
    "bullmq": "^5.16.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "minio": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "resend": "^6.12.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.14.4"
  }
}
