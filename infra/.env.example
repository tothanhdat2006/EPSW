# PostgreSQL
DATABASE_URL=postgresql://dvc_user:dvc_password@localhost:5432/dvc_db

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=dvc-service
KAFKA_GROUP_ID=dvc-group

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET_DOCUMENTS=dvc-documents
MINIO_BUCKET_REDACTED=dvc-redacted
MINIO_BUCKET_PUBLISHED=dvc-published

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=dvc
KEYCLOAK_CLIENT_ID=dvc-backend
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=dvc-workflow

# LLM / AI
LLM_PROVIDER=alibaba
# Recommended: use generic key for any provider
LLM_API_KEY=CHANGE_ME
# Optional override (defaults to DashScope OpenAI-compatible endpoint when provider=alibaba)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Alibaba/DashScope models: qwen-turbo | qwen-plus | qwen-max (choose per budget/latency)
LLM_MODEL=qwen-plus
# Backward-compat (deprecated): some components may still read this
OPENAI_API_KEY=sk-...

# Notification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change-me
SMS_GATEWAY_URL=https://sms.example.com/api/send
ZALO_OA_ACCESS_TOKEN=...

# General
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
