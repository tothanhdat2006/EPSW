# Example — DO NOT commit real secrets. Use a secrets manager (Vault, AWS SSM, etc.)
apiVersion: v1
kind: Secret
metadata:
  name: dvc-postgres-secret
  namespace: dvc-system
type: Opaque
stringData:
  url: postgresql://dvc_user:CHANGE_ME@postgres:5432/dvc_db
  password: CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: dvc-minio-secret
  namespace: dvc-system
type: Opaque
stringData:
  accessKey: CHANGE_ME
  secretKey: CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: dvc-llm-secret
  namespace: dvc-system
type: Opaque
stringData:
  apiKey: sk-CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: dvc-smtp-secret
  namespace: dvc-system
type: Opaque
stringData:
  host: smtp.example.com
  user: noreply@example.com
  password: CHANGE_ME
