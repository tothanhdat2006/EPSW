generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  NORMAL
  URGENT
  FLASH
}

enum DocStatus {
  RECEIVED
  PROCESSING
  HITL_REVIEW
  VALIDATED
  REJECTED
  APPROVED
  PUBLISHED
}

enum SecurityLevel {
  UNCLASSIFIED
  RESTRICTED
  CONFIDENTIAL
  SECRET
}

model Document {
  id              String        @id @default(uuid())
  trackingCode    String        @unique
  submitterId     String
  priority        Priority      @default(NORMAL)
  status          DocStatus     @default(RECEIVED)

  rawFileUrl      String
  redactedFileUrl String?

  extractedData   Json?
  aiConfidence    Float?
  securityLevel   SecurityLevel @default(UNCLASSIFIED)

  slaDeadline     DateTime?
  assignedDept    String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  hitlTasks       HitlTask[]
  auditLogs       AuditLog[]

  @@index([status])
  @@index([submitterId])
  @@index([trackingCode])
}

model HitlTask {
  id             String    @id @default(uuid())
  documentId     String
  document       Document  @relation(fields: [documentId], references: [id])

  taskType       String
  assignedRole   String
  assignedUserId String?

  status         String    @default("PENDING")
  resolutionData Json?

  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([documentId])
  @@index([assignedRole, status])
}

model AuditLog {
  id           String   @id @default(uuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id])

  action       String
  actorId      String
  actorRole    String
  correlationId String
  metadata     Json?

  createdAt    DateTime @default(now())

  @@index([documentId])
  @@index([correlationId])
}
